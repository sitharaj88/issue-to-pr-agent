# ==============================================================================
# Issue-to-PR Agent — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the required values.
# Lines starting with # are comments. Remove # to enable a setting.

# ------------------------------------------------------------------------------
# Core
# ------------------------------------------------------------------------------

# Environment mode: "development" or "production".
# In production: auth is mandatory, stricter validation is enforced.
# ISSUE_TO_PR_ENV=development

# Path to the artifact directory where runs, receipts, and reports are stored.
# Required for all operations.
ISSUE_TO_PR_ARTIFACT_DIR=.issue-to-pr

# Branch prefix for agent-created branches (e.g., "agent/issue-42").
# ISSUE_TO_PR_BRANCH_PREFIX=agent/

# Maximum number of repository files to analyze during planning.
# ISSUE_TO_PR_MAX_REPO_FILES=200

# Git remote name used for push operations.
# ISSUE_TO_PR_GIT_REMOTE=origin

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# ISSUE_TO_PR_LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------

# Backend: "sqlite" (single instance) or "postgres" (multi-worker).
# In production with multiple workers, postgres is required.
# ISSUE_TO_PR_DATABASE_BACKEND=sqlite

# Database URL. Required when using postgres.
# Example: postgresql://user:password@localhost:5432/issue_to_pr
# ISSUE_TO_PR_DATABASE_URL=

# SQLite database path override (default: <artifact_dir>/agent_runs.sqlite3).
# ISSUE_TO_PR_DB_PATH=

# ------------------------------------------------------------------------------
# Authentication & Authorization
# ------------------------------------------------------------------------------

# Static API bearer token. Requests must include: Authorization: Bearer <token>.
# In production, at least one auth mechanism (api_token or auth_token_secret) is required.
# ISSUE_TO_PR_API_TOKEN=

# HMAC secret for signing/verifying JWT bearer tokens (min 32 chars).
# ISSUE_TO_PR_AUTH_TOKEN_SECRET=

# Expected JWT issuer claim. Tokens with a different issuer are rejected.
# ISSUE_TO_PR_AUTH_TOKEN_ISSUER=

# ------------------------------------------------------------------------------
# API Server
# ------------------------------------------------------------------------------

# Bind host and port for the HTTP API server.
# ISSUE_TO_PR_API_HOST=127.0.0.1
# ISSUE_TO_PR_API_PORT=8080

# Rate limit: maximum requests per minute per client.
# ISSUE_TO_PR_API_RATE_LIMIT_PER_MINUTE=120

# CORS: allowed origin for cross-origin requests from the UI.
# Example: https://dashboard.example.com
# ISSUE_TO_PR_CORS_ALLOWED_ORIGIN=

# Base URL for artifact links in API responses.
# ISSUE_TO_PR_ARTIFACT_BASE_URL=

# ------------------------------------------------------------------------------
# Integrations — GitHub
# ------------------------------------------------------------------------------

# GitHub personal access token for fetching issues and creating PRs.
# Required for plan, deliver, and webhook operations.
# GITHUB_TOKEN=

# Webhook secret for verifying GitHub webhook signatures (HMAC-SHA256).
# ISSUE_TO_PR_WEBHOOK_SECRET=

# Path to JSON file mapping repo full names to local repo root paths.
# Required for webhook-triggered operations.
# ISSUE_TO_PR_WEBHOOK_REPO_ROOTS_PATH=

# Default actor and team for webhook-triggered operations.
# ISSUE_TO_PR_WEBHOOK_ACTOR=webhook
# ISSUE_TO_PR_WEBHOOK_TEAM=automation

# ------------------------------------------------------------------------------
# Integrations — OpenAI
# ------------------------------------------------------------------------------

# OpenAI API key. Required when using the OpenAI planner or patcher.
# OPENAI_API_KEY=

# Model name for complex planning and patching tasks.
# ISSUE_TO_PR_OPENAI_COMPLEX_MODEL=gpt-4

# ------------------------------------------------------------------------------
# Integrations — Jira
# ------------------------------------------------------------------------------

# Jira instance base URL.
# ISSUE_TO_PR_JIRA_BASE_URL=

# Jira API token.
# ISSUE_TO_PR_JIRA_TOKEN=

# Jira webhook verification secret.
# ISSUE_TO_PR_JIRA_WEBHOOK_SECRET=

# Path to JSON file mapping Jira projects to GitHub repos.
# ISSUE_TO_PR_JIRA_PROJECT_MAPPINGS_PATH=

# ------------------------------------------------------------------------------
# Integrations — Slack & Teams
# ------------------------------------------------------------------------------

# Slack webhook URL for notifications.
# ISSUE_TO_PR_SLACK_WEBHOOK_URL=

# Slack signing secret for verifying Slack webhook requests.
# ISSUE_TO_PR_SLACK_SIGNING_SECRET=

# Microsoft Teams webhook URL for notifications.
# ISSUE_TO_PR_TEAMS_WEBHOOK_URL=

# ------------------------------------------------------------------------------
# Queue & Worker
# ------------------------------------------------------------------------------

# Maximum number of attempts before a job is marked as failed.
# ISSUE_TO_PR_QUEUE_MAX_ATTEMPTS=3

# Lease duration in seconds. Jobs not completed within this time are requeued.
# ISSUE_TO_PR_QUEUE_LEASE_SECONDS=600

# Backoff duration in seconds between failed attempts.
# ISSUE_TO_PR_QUEUE_BACKOFF_SECONDS=60

# Maximum running jobs per worker and per tenant.
# ISSUE_TO_PR_QUEUE_MAX_RUNNING_JOBS_PER_WORKER=2
# ISSUE_TO_PR_QUEUE_MAX_RUNNING_JOBS_PER_TENANT=5

# Maximum candidates scanned per claim cycle.
# ISSUE_TO_PR_QUEUE_CANDIDATE_SCAN_LIMIT=50

# Budget configuration: max units per job and max pending jobs.
# ISSUE_TO_PR_BUDGET_MAX_UNITS_PER_JOB=10
# ISSUE_TO_PR_BUDGET_MAX_PENDING_JOBS=100
# ISSUE_TO_PR_BUDGET_MAX_PENDING_JOBS_PER_TENANT=20

# Cost per operation type (in budget units).
# ISSUE_TO_PR_BUDGET_COST_PLAN_HEURISTIC=1
# ISSUE_TO_PR_BUDGET_COST_PLAN_OPENAI=3
# ISSUE_TO_PR_BUDGET_COST_VERIFY=2
# ISSUE_TO_PR_BUDGET_COST_DELIVER=1

# ------------------------------------------------------------------------------
# Docker Execution Runtime
# ------------------------------------------------------------------------------

# Runtime for verification commands: "local" or "docker".
# ISSUE_TO_PR_VERIFICATION_RUNTIME=local

# Docker binary path.
# ISSUE_TO_PR_DOCKER_BINARY=docker

# Docker image for sandboxed command execution.
# ISSUE_TO_PR_DOCKER_IMAGE=python:3.11-slim

# Docker resource limits.
# ISSUE_TO_PR_DOCKER_CPUS=1
# ISSUE_TO_PR_DOCKER_MEMORY_MB=512
# ISSUE_TO_PR_DOCKER_NETWORK=none

# ------------------------------------------------------------------------------
# Sandbox
# ------------------------------------------------------------------------------

# Directory for sandbox workspaces.
# ISSUE_TO_PR_SANDBOX_DIR=

# Maximum file size in bytes for sandbox copies.
# ISSUE_TO_PR_SANDBOX_MAX_FILE_BYTES=10485760

# ------------------------------------------------------------------------------
# Approvals
# ------------------------------------------------------------------------------

# Path to JSON approval policy file.
# ISSUE_TO_PR_APPROVAL_POLICY_PATH=

# Default TTL for approval requests in hours.
# ISSUE_TO_PR_APPROVAL_TTL_HOURS=72

# ------------------------------------------------------------------------------
# Delivery Governance
# ------------------------------------------------------------------------------

# Path to JSON delivery governance policy file.
# ISSUE_TO_PR_DELIVERY_GOVERNANCE_POLICY_PATH=

# ------------------------------------------------------------------------------
# Model Routing
# ------------------------------------------------------------------------------

# Complexity thresholds for routing to complex models.
# ISSUE_TO_PR_ROUTER_PLANNER_COMPLEXITY_THRESHOLD=0.7
# ISSUE_TO_PR_ROUTER_PATCH_COMPLEXITY_THRESHOLD=0.7

# ------------------------------------------------------------------------------
# Observability & Telemetry
# ------------------------------------------------------------------------------

# Directory for metrics output (JSON + Prometheus text).
# ISSUE_TO_PR_METRICS_DIR=

# Directory for telemetry event storage.
# ISSUE_TO_PR_TELEMETRY_DIR=

# URL for the external telemetry sink (POST events).
# ISSUE_TO_PR_TELEMETRY_SINK_URL=

# Directory for notification payloads.
# ISSUE_TO_PR_NOTIFICATION_DIR=

# Directory for audit export archives.
# ISSUE_TO_PR_AUDIT_EXPORT_DIR=

# Artifact storage backend and base URL.
# ISSUE_TO_PR_ARTIFACT_STORE_BACKEND=local
# ISSUE_TO_PR_ARTIFACT_STORE_BASE_URL=
# ISSUE_TO_PR_ARTIFACT_STORE_DIR=

# ------------------------------------------------------------------------------
# Retention
# ------------------------------------------------------------------------------

# Retention periods in days for automatic cleanup.
# ISSUE_TO_PR_RETENTION_ALERT_DAYS=90
# ISSUE_TO_PR_RETENTION_NOTIFICATION_DAYS=30
# ISSUE_TO_PR_RETENTION_TRACE_DAYS=30
# ISSUE_TO_PR_RETENTION_WORKER_HEARTBEAT_DAYS=7

# ------------------------------------------------------------------------------
# Alerting
# ------------------------------------------------------------------------------

# Alert thresholds.
# ISSUE_TO_PR_ALERT_FAILED_JOBS_THRESHOLD=5
# ISSUE_TO_PR_ALERT_STALE_LEASE_THRESHOLD=3
# ISSUE_TO_PR_ALERT_DEDUPE_SECONDS=300
